{
  "name": "dietplanner",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --android",
    "android": "expo run:android",
    "check": "node --check index.js && node --check src/App.js && node --check src/engine/nutritionEngine.js && node --check src/data/foods.js && node --check src/engine/skrPayments.js",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.1.3",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.1.3",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "buffer": "^6.0.3",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-task-manager": "~12.0.6",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-url-polyfill": "^2.0.0"
  }
}
